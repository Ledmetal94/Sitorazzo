{
  "outputDirectory": ".",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/submit-brief.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }]
    }
  ]
}
